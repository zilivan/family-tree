generator client {
  provider = "prisma-client-js" 
  
  // УБРАТЬ: output = "../src/generated/prisma" (временно)
  
}

datasource db {
  provider = "postgresql" 
  
}

model Person {
  id          String    @id @default(cuid())
  firstName   String
  lastName    String
  parentLastName String?
  patronymic  String?
  birthDate   DateTime?
  deathDate   DateTime?
  gender      String?   // "male", "female", "other"
  phone       String?
  fatherId  String?
  motherId  String?
  father    Person?  @relation("Father", fields: [fatherId], references: [id])
  mother    Person?  @relation("Mother", fields: [motherId], references: [id])
  childrenAsFather Person[] @relation("Father")
  childrenAsMother Person[] @relation("Mother")
  marriagesAsHusband Marriage[] @relation("MarriageToPersonAsHusband")
  marriagesAsWife    Marriage[] @relation("MarriageToPersonAsWife")
  photos      Photo[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      String?   @unique              // ← внешний ключ
   user      User?   @relation("UserPerson", fields: [userId], references: [id]) // ← связь
  createdById String?   
  creator     User?    @relation("PersonCreator", fields: [createdById], references: [id])
  branch      String    @default("base")     // ← обязательно для ТЗ
  status      PersonStatus  @default(PENDING)
  pendingRegistration PendingRegistration?
  modeStatus ModeStatus  @default(NEW)// create , edit , new 
  modeStatusEditId String?
 
}

model Marriage {
  id         String   @id @default(cuid())
  husband    Person @relation("MarriageToPersonAsHusband", fields: [husbandId], references: [id])
  wife       Person @relation("MarriageToPersonAsWife", fields: [wifeId], references: [id])
 husbandId  String
  wifeId     String
  status     PersonStatus  @default(PENDING) // ACTIVE, DIVORCED, WIDOWED
  place      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  branch     String   @default("base")
  originalMarriageId String? // для edit-ветки

  @@unique([husbandId, wifeId]) // Один человек не может быть женат на другом дважды
}

model Photo {
  id        String   @id @default(cuid())
  url       String
  personId  String
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
model User {
  id             String   @id @default(cuid())
  email          String?  @unique
  phone          String?  @unique
  isAdmin        Boolean  @default(false)
  isBlocked      Boolean  @default(false)
  isVerified     Boolean  @default(false)
  verificationCode String? @unique
  oneTimeToken   String?  @unique
  verifiedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  person    Person?  @relation("UserPerson")
  personId          String?
  createdPersons    Person[] @relation("PersonCreator")
}
model ChatMessage {
  id        String   @id @default(cuid())
  text      String
  userName  String
  isGuest   Boolean
  createdAt DateTime @default(now())
}
enum PersonStatus {
  PENDING    // Ожидает подтверждения
  CONFIRMED  // Подтверждена
}


enum ModeStatus {
CREATE 
 EDIT 
  NEW 
}
model PendingRegistration {
  id        String   @id @default(cuid())
  email     String
  personId  String   @unique
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}