# ======================
# Logs
# ======================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ======================
# Editor directories and files
# ======================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ======================
# Frontend
# ======================
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.cache/
frontend/.env
!.frontend/.env.example

# ======================
# Backend
# ======================
backend/node_modules/
backend/dist/
backend/build/
backend/*.log
backend/.env
!.backend/.env.example

# ======================
# Prisma
# ======================
# Игнорируем сгенерированный клиент (он создаётся при установке)
node_modules/.prisma/
**/.prisma/

# НЕ игнорируем схему и миграции!
# prisma/schema.prisma
# prisma/migrations/

# ======================
# Загрузки и медиа
# ======================
# Игнорируем все загруженные файлы
uploads/
backend/uploads/
frontend/uploads/

# НО сохраняем структуру папок через .gitkeep
!uploads/.gitkeep
!backend/uploads/.gitkeep
!backend/uploads/photos/.gitkeep
!frontend/uploads/.gitkeep

# ======================
# TypeScript
# ======================
*.tsbuildinfo
*.tsbuildinfo.*

