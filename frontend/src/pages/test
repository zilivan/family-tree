import { useState, useMemo } from 'react';
import { Select } from '@mantine/core';
import { useDebouncedValue } from '@mantine/hooks';
import { useSearchPersonsQuery, useGetPersonQuery } from '../../api/personsApi';

interface PersonSearchSelectProps {
  label: string;
  value: string | null;
  onChange: (value: string | null) => void;
  branch: string;
  excludeIds?: string[];
}

export function PersonSearchSelect({
  label,
  value,
  onChange,
  branch,
  excludeIds = [],
}: PersonSearchSelectProps) {
  const [search, setSearch] = useState('');
  const [debouncedSearch] = useDebouncedValue(search, 300);

  // Загружаем ВСЕХ персон, если поиск пустой
  const shouldSkipSearch = debouncedSearch.trim().length < 2; // ← минимальная длина 2 символа


  const  resultQuery  = useSearchPersonsQuery(
    { query: shouldSkipSearch ? '' : debouncedSearch, branch },
    { skip: false } // ← НЕ ПРОПУСКАЕМ запрос!
  );
  const searchResults = resultQuery.data;

  // Загружаем текущее значение
  const   resultPerson  = useGetPersonQuery(
    { id: value!, branch },
    { skip: !value }
  );
const currentPerson = resultPerson.data


  // Фильтруем результаты
  const filteredResults = useMemo(() => {
    let results = searchResults;
    
    // Если поиск короткий — показываем всех
    /*
    if (shouldSkipSearch) {
      results = searchResults;
    } else {
      // Иначе фильтруем по поиску
      const query = debouncedSearch.toLowerCase();
      results = searchResults.filter(p => 
        `${p.lastName} ${p.firstName} ${p.patronymic || ''}`.toLowerCase().includes(query)
      );
    }
    
    return results.filter(p => !excludeIds.includes(p.id));
  }, [searchResults, debouncedSearch, excludeIds, shouldSkipSearch]);
*/
  // Опции для Select
  const selectOptions = useMemo(() => 
    filteredResults.map(person => ({
      value: person.id,
      label: `${person.lastName} ${person.firstName} ${person.patronymic || ''}`.trim(),
    })), 
    [filteredResults]
  );

  // Добавляем текущее значение, если его нет в списке
  const displayedData = useMemo(() => {
    const options = [...selectOptions];
    
    if (value && currentPerson) {
      const currentOption = {
        value: currentPerson.id,
        label: `${currentPerson.lastName} ${currentPerson.firstName} ${currentPerson.patronymic || ''}`.trim()
      };
      
      if (!options.some(opt => opt.value === value)) {
        options.unshift(currentOption);
      }
    }
    
    return options;
  }, [value, currentPerson, selectOptions]);

  return (
    <Select
      label={label}
      placeholder="Начните вводить ФИО..."
      searchable
      clearable
      data={displayedData}
      value={value}
      onChange={onChange}
      onSearchChange={setSearch}
      maxDropdownHeight={200}
    
      
    />
  );
}

