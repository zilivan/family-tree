// Form 

// types
interface FormState {
  field1: string;
  field2: string;
  field3: string;
  field4: string;
  field5: string;
  field6: string;
  field7: string;
  field8: string;
  field9: string;
  field10: string;
}

type FormAction = 
  | { type: 'SET_FIELD'; field: keyof FormState; value: string }
  | { type: 'RESET' };


// reducer
 const initialFormState:FormState = {
 field1: '',
  field2: '',
  field3: '',
  field4: '',
  field5: '',
  field6: '',
  field7:  '',
  field8:  '',
  field9:  '',
  field10:  ''
}

const formReducer = (state: FormState, action: FormAction): FormState => {
   switch(action.type) {
   case "SET_FIELD" : return {
      ...state,[action.field]:action.value
   }
   case "RESET":  return initialFormState
   default: return  state
    };
   };

// компонент поля
interface FieldProps {
  label: keyof FormState;
  value: string;
  onChange: ( value: string) => void;
}
 export const Field = memo(({ label, value, onChange }: FieldProps) => { 
   return(
<div>
<label>{label}</label> 
<input
type = "text"
value={value}
placeholder={`Input volume:${label}`}
onChange ={(e) => onChange(e.target.value) }
>
</div>
)});

// основная форма

import {useReducer,useCallback} from 'react'

export const  OptimizedForm = () => { 

 const [formState,dispatch ]  = useReducer(formReducer,initialFormState )

const configField = Object.keys(initialFormState) as (keyof FormState)[];


const handleOnchage = useCallback((fild:keyof FormState) =>{
return (volume:string)=> {
dispatch({type: 'SET_FIELD',field:fild,value:volume })
}},[])

const handleReset = useCallback(()=>{
  dispatch({type: 'RESET'})
},[])

return (

<form>
{configField.map(fild => (
<Field
key= {fild}
label= {fild}
value ={formState[fild]}
onChange={handleOnchage(fild)}
/>
))}

<button
type="button"
onClick={handleReset}
>
RESET
</button>
<button
type="submit"
>
SEND FORM
</button>
</form>
)
 };


 